# Copy this to config/model.env if you want to override defaults.

MODEL_REPO="HauhauCS/Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive"
MODEL_QUANT="Q8_K_P"

# Q8_K_P is around 44 GB before KV cache and is intended for 80 GB GPUs.
# If VRAM is tight, lower CTX_SIZE first, then try Q4_K_M, IQ3_M, or IQ2_M.
# MODEL_QUANT="Q4_K_M"

PORT="8080"
CTX_SIZE="131072"
N_GPU_LAYERS="99"
PARALLEL="1"

# Add extra llama-server args here only when needed.
# LLAMA_EXTRA_ARGS="--verbose"
